/**
 * credentials.h.example — copy to credentials.h and fill in your values.
 * credentials.h is gitignored and never committed.
 *
 * Find your Mac's IP:  ipconfig getifaddr en0
 * Start UDP listener:  just log-listen        (or: nc -u -l 4444)
 */
#pragma once

#define WIFI_SSID     "your-wifi-ssid"
#define WIFI_PASSWORD "your-wifi-password"
#define LOG_UDP_HOST  "192.168.x.x"  /* Mac IP on the same network */
#define LOG_UDP_PORT  4444
