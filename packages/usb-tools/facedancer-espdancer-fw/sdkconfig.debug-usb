# Debug overlay — raw DCD active + verbose logging over WiFi UDP.
# USB PHY goes to the vendored DCD (USB-Serial-JTAG unavailable).
# Monitor via: just log-listen  (join 'espdancer-log' WiFi first)
# Usage: rm sdkconfig && just build-debug-usb

CONFIG_USJ_ENABLE_USB_SERIAL_JTAG=n
CONFIG_ESP_CONSOLE_SECONDARY_NONE=y

CONFIG_LOG_DEFAULT_LEVEL_DEBUG=y
CONFIG_LOG_DEFAULT_LEVEL=4
CONFIG_LOG_MAXIMUM_LEVEL=4