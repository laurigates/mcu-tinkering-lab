# Xbox-Switch Bridge — ESP32-S3 Bluetooth-to-USB Controller Bridge
# Run `just --list` or `just xbox::help` to see available recipes

set positional-arguments

import '../../../tools/esp32.just'

project_dir := "packages/esp32-projects/xbox-switch-bridge"
tools_dir := justfile_directory() / "../../.." / "tools"
port := env("PORT", _detected_s3)
baud := env("BAUD", "460800")
target := "esp32s3"

# Bluepad32 dependency
bp32_version := "release_v3.10.3"
bp32_repo := "https://github.com/ricardoquesada/bluepad32.git"

default:
    @just --list

##########
# Setup
##########

# Check if generated sdkconfig is stale (older than any sdkconfig.defaults/overlay)
[private]
check-sdkconfig:
    #!/usr/bin/env bash
    set -euo pipefail
    [ -f sdkconfig ] || exit 0  # No sdkconfig yet — fresh build, nothing to check
    stale=()
    for src in sdkconfig.defaults sdkconfig.debug-jtag sdkconfig.debug-uart sdkconfig.debug-usb sdkconfig.wifi-test; do
        [ -f "$src" ] || continue
        if [ "$src" -nt sdkconfig ]; then
            stale+=("$src")
        fi
    done
    if [ ${#stale[@]} -gt 0 ]; then
        echo "WARNING: sdkconfig is stale — newer than generated config:" >&2
        printf "  %s\n" "${stale[@]}" >&2
        echo "" >&2
        echo "Run 'rm sdkconfig && just clean' before building, or values" >&2
        echo "from sdkconfig.defaults won't take effect." >&2
        echo "" >&2
        read -r -p "Delete sdkconfig and continue? [y/N] " answer
        if [[ "$answer" =~ ^[Yy] ]]; then
            rm -f sdkconfig
            echo "Deleted sdkconfig — will regenerate from defaults on next build"
        else
            echo "Continuing with stale sdkconfig (some settings may be outdated)" >&2
        fi
    fi

# Clone external dependencies and prepare btstack component
[group: "setup"]
fetch-deps:
    #!/usr/bin/env bash
    set -euo pipefail
    BP32_DIR="external/bluepad32"
    BTSTACK_ROOT="$BP32_DIR/external/btstack"
    BTSTACK_COMP="$BTSTACK_ROOT/port/esp32/components/btstack"

    if [ ! -d "$BP32_DIR/src" ]; then
        echo "Cloning bluepad32 {{bp32_version}}..."
        git clone --depth 1 --branch {{bp32_version}} {{bp32_repo}} "$BP32_DIR"
        (cd "$BP32_DIR" && git submodule update --init --depth 1 external/btstack)
    fi

    # BTstack component needs source dirs copied into component directory
    # (btstack's CMakeLists uses relative paths from the component dir)
    if [ ! -d "$BTSTACK_COMP/src" ]; then
        echo "Preparing btstack component..."
        DIRS=(
            "src"
            "3rd-party/bluedroid"
            "3rd-party/hxcmod-player"
            "3rd-party/lwip/dhcp-server"
            "3rd-party/lc3-google"
            "3rd-party/md5"
            "3rd-party/micro-ecc"
            "3rd-party/yxml"
            "platform/freertos"
            "platform/lwip"
        )
        for dir in "${DIRS[@]}"; do
            mkdir -p "$BTSTACK_COMP/$(dirname "$dir")"
            cp -r "$BTSTACK_ROOT/$dir" "$BTSTACK_COMP/$dir"
        done
        # platform/embedded needs only specific files
        mkdir -p "$BTSTACK_COMP/platform/embedded"
        for f in hal_time_ms.h hal_uart_dma.h hci_dump_embedded_stdout.h hci_dump_embedded_stdout.c; do
            cp "$BTSTACK_ROOT/platform/embedded/$f" "$BTSTACK_COMP/platform/embedded/"
        done
        echo "btstack component prepared"
    fi
    echo "Dependencies ready"

# Remove external dependencies
[confirm("Remove external dependencies and rebuild from scratch?")]
[group: "setup"]
clean-deps:
    rm -rf external/

##########
# Build (containerized)
##########

# Build firmware in Docker container
[group: "build"]
build: check-sdkconfig fetch-deps (_idf-build "")

# Build debug firmware (USB-Serial-JTAG stays alive for log output, TinyUSB disabled)
[group: "build"]
build-debug-jtag: check-sdkconfig fetch-deps (_idf-build "sdkconfig.debug-jtag")
    @echo "Flash with: just flash"

# Build debug firmware with TinyUSB active + UART logging via CP2102 (GPIO43/44)
# Monitor with: just uart-monitor
[group: "build"]
build-debug-uart: check-sdkconfig fetch-deps (_idf-build "sdkconfig.debug-uart")
    @echo "Monitor via: just uart-monitor (CP2102 on GPIO43/44)"

# Build debug firmware with TinyUSB active (for Switch handshake debugging)
# Logs only via WiFi UDP — connect to "xbox-bridge-log", then: just log-listen
[group: "build"]
build-debug-usb: check-sdkconfig fetch-deps (_idf-build "sdkconfig.debug-usb")
    @echo "Monitor via: just log-listen (connect to xbox-bridge-log WiFi first)"

# Build WiFi-only test firmware (no BLE — isolates SoftAP visibility)
# If AP is visible with this build, the problem is BLE coexistence
[group: "build"]
build-wifi-test: check-sdkconfig fetch-deps (_idf-build "sdkconfig.wifi-test")
    @echo "Then check if 'xbox-bridge-log' WiFi network is visible"

# Shared build helper — overlay is empty string for production build
[private]
_idf-build overlay:
    #!/usr/bin/env bash
    set -euo pipefail
    overlay="{{overlay}}"
    if [ -n "$overlay" ]; then
        sdk_env="SDKCONFIG_DEFAULTS=\"sdkconfig.defaults;$overlay\""
        label="${overlay#sdkconfig.}"
    else
        sdk_env=""
        label="production"
    fi
    echo "Building [$label]..."
    {{container_cmd}} compose -f {{compose_file}} run --rm \
        -w /workspace/{{project_dir}} \
        esp-idf \
        bash -c "${sdk_env:+$sdk_env }idf.py set-target {{target}} && idf.py build" 2>&1 \
        | grep -E "warning:|error:|ninja: build stopped|binary size|Build complete" \
        || true
    # Verify binary was produced
    if [ ! -f build/xbox-switch-bridge.bin ]; then
        echo "FAILED — rerun with verbose output:" >&2
        echo "  {{container_cmd}} compose -f {{compose_file}} run --rm -w /workspace/{{project_dir}} esp-idf bash -c 'idf.py build'" >&2
        exit 1
    fi
    echo "Build OK [$label]"

# Clean build artifacts via container
[group: "build"]
clean:
    #!/usr/bin/env bash
    set -euo pipefail
    {{container_cmd}} compose -f {{compose_file}} run --rm \
        -w /workspace/{{project_dir}} \
        esp-idf \
        idf.py fullclean
    echo "Clean complete"

# Open menuconfig via container
[group: "build"]
menuconfig:
    {{container_cmd}} compose -f {{compose_file}} run --rm \
        -w /workspace/{{project_dir}} \
        esp-idf \
        idf.py menuconfig

# Interactive shell in ESP-IDF container (project directory)
[group: "build"]
shell:
    {{container_cmd}} compose -f {{compose_file}} run --rm \
        -w /workspace/{{project_dir}} \
        esp-idf \
        /bin/bash

##########
# Flash & Monitor (native — USB passthrough on macOS is unreliable)
##########

# Auto-detect ESP32-S3 port or show error
[group: "device"]
detect-port:
    "{{tools_dir}}/detect-esp32s3-port.sh"

# Flash firmware to device
[group: "device"]
flash: require-port
    #!/usr/bin/env bash
    set -euo pipefail
    esptool -s --chip esp32s3 -p {{port}} -b {{baud}} \
        --before default-reset --after hard-reset \
        write-flash --flash-mode dio --flash-size 4MB --flash-freq 80m \
        0x0 build/bootloader/bootloader.bin \
        0x8000 build/partition_table/partition-table.bin \
        0x10000 build/xbox-switch-bridge.bin
    echo "Flashed OK"

# Reset board via USB-Serial-JTAG CDC control signals
[group: "device"]
reset: require-port
    "{{tools_dir}}/esp32s3-reset.sh" "{{port}}"

# Serial monitor with reset (Ctrl-C to stop)
[group: "device"]
monitor: require-port
    "{{tools_dir}}/esp32s3-monitor.sh" "{{port}}"

# Flash and monitor
[group: "device"]
flash-monitor: flash monitor

##########
# Info
##########

# Listen for UDP log broadcast from the device
# 1. Connect Mac to "xbox-bridge-log" WiFi (password: xboxbridge)
# 2. Run this recipe
[group: "device"]
log-listen port="4444":
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Listening for UDP logs on port {{port}} — Ctrl-C to stop"
    echo "Connect to WiFi: xbox-bridge-log (password: xboxbridge)"
    echo ""
    exec socat -u UDP-RECV:{{port}} -

# Scan for xbox-bridge-log WiFi AP
[group: "device"]
wifi-scan:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Scanning for WiFi networks..."
    echo ""
    python3 "{{tools_dir}}/wifi-scan.py" "xbox-bridge-log" 2>/dev/null || {
        # Fallback: try connecting (networksetup reports if SSID exists)
        if /usr/sbin/networksetup -setairportnetwork en0 "xbox-bridge-log" 2>&1 | grep -q "Could not find"; then
            echo "xbox-bridge-log: NOT FOUND"
        else
            echo "xbox-bridge-log: FOUND (connected!)"
        fi
    }
    echo ""
    echo "Current connection:"
    /usr/sbin/networksetup -getairportnetwork en0 2>/dev/null || echo "  (unknown)"

# Try to connect to the ESP32-S3 log AP
[group: "device"]
wifi-connect:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Connecting to xbox-bridge-log..."
    if /usr/sbin/networksetup -setairportnetwork en0 "xbox-bridge-log" "xboxbridge" 2>&1 | grep -q "Could not find"; then
        echo "FAILED: Network not found"
        echo ""
        echo "Troubleshooting:"
        echo "  - Is the ESP32-S3 powered on and running?"
        echo "  - Check LED: cyan flash = AP ready"
        echo "  - BLE + SoftAP coexistence is unstable on ESP32-S3"
        echo "  - Try: just build-wifi-test (disables BLE to isolate)"
        exit 1
    fi
    echo "Connected! IP: $(ipconfig getifaddr en0 2>/dev/null || echo 'pending...')"
    echo "Run: just log-listen"

# Auto-detect CP2102 USB-UART adapter; override with UART_PORT env var
uart_port := env("UART_PORT", _detected_uart)
uart_baud := env("UART_BAUD", "115200")
uart_flash_baud := env("UART_FLASH_BAUD", "460800")

# Require a valid UART port for adapter recipes
[private]
require-uart-port:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ -z "{{uart_port}}" ]; then
        echo "ERROR: No CP2102 USB-UART device found" >&2
        echo "  Is the adapter plugged in? Override with: UART_PORT=/dev/cu.usbserial-0001 just flash-uart" >&2
        exit 1
    fi

# Flash firmware via USB-UART adapter (requires RTS→EN and DTR→GPIO0 wired for auto-reset)
# Wiring: UART TX→GPIO44, RX→GPIO43, RTS→EN, DTR→GPIO0, GND→GND
[group: "device"]
flash-uart: require-uart-port
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Flashing via UART adapter {{uart_port}} @ {{uart_flash_baud}} baud"
    esptool -s --chip esp32s3 -p {{uart_port}} -b {{uart_flash_baud}} \
        --before default-reset --after hard-reset \
        write-flash --flash-mode dio --flash-size 4MB --flash-freq 80m \
        0x0 build/bootloader/bootloader.bin \
        0x8000 build/partition_table/partition-table.bin \
        0x10000 build/xbox-switch-bridge.bin
    echo "Flashed OK"

# Flash via UART adapter then open serial monitor
[group: "device"]
flash-monitor-uart: flash-uart uart-monitor

# Monitor UART via CP2102 USB-UART adapter (Ctrl-C to stop)
[group: "device"]
uart-monitor: require-uart-port
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Monitoring {{uart_port}} @ {{uart_baud}} baud — Ctrl-C to stop"
    exec uvx --from pyserial python3 -c "
    import serial, sys, signal
    signal.signal(signal.SIGINT, lambda *a: sys.exit(0))
    s = serial.Serial('{{uart_port}}', {{uart_baud}}, timeout=1)
    try:
        while True:
            data = s.read(4096)
            if data:
                sys.stdout.buffer.write(data)
                sys.stdout.buffer.flush()
    except serial.SerialException:
        print('\nDevice disconnected', file=sys.stderr)
    "

# Show project information
[group: "info"]
info:
    @echo "Project: xbox-switch-bridge"
    @echo "  Target:    ESP32-S3"
    @echo "  Port (JTAG):  {{if port == "" { "(not detected — board not connected?)" } else { port } }}"
    @echo "  Port (UART):  {{if uart_port == "" { "(not detected — adapter not connected?)" } else { uart_port } }}"
    @echo "  Baud (flash): {{baud}} / UART: {{uart_flash_baud}}"
    @echo "  Container: {{container_cmd}}"
    @echo ""
    @echo "  USB VID: 0x057E (Nintendo)"
    @echo "  USB PID: 0x2009 (Pro Controller)"
    @echo ""
    @echo "  Bluepad32: {{bp32_version}}"
