info:
    @echo "{{project_name}} — AI Vision with Telegram Integration"
    @echo "  Target:    ESP32"
    @echo "  Port:      {{port}}"
    @echo "  Container: {{container_cmd}}"
    @echo ""
    @echo "Features:"
    @echo "  Camera capture with OV2640"
    @echo "  LLM-powered image analysis"
    @echo "  Telegram bot interface"
    @echo "  Motor control via vision commands"
    @echo ""
    @echo "Note: Credentials are in main/config.h (placeholder values)."
    @echo "  Edit config.h with your WiFi, Telegram, and LLM API credentials."
    @echo "  Uses custom partition table (partitions.csv)."
    @echo "  data/prompts.txt is embedded into the binary at build time."
    @echo ""
    @echo "Programming ESP32-CAM:"
    @echo "  1. Connect GPIO0 to GND"
    @echo "  2. Power on or reset the board"
    @echo "  3. Run: just flash or just flash-monitor"
    @echo "  4. Disconnect GPIO0 from GND after flashing"
    @echo "  5. Reset the board to run the new firmware"
