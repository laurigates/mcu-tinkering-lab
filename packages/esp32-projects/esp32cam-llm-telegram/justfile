# ESP32-CAM LLM Telegram Bot — AI vision with Telegram integration
# Run `just` or `just --list` to see available recipes

set positional-arguments

idf_path := env("IDF_PATH", home_directory() + "/repos/esp-idf")
port := env("PORT", "/dev/cu.usbserial-0001")
project_name := "esp32cam-llm-telegram"

default:
    @just --list

[private]
check-idf:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ ! -d "{{idf_path}}" ]; then
        echo "Error: ESP-IDF not found at {{idf_path}}"
        echo "Install ESP-IDF or set IDF_PATH variable"
        exit 1
    fi

##########
# Build
##########

# Build the firmware
[group: "build"]
build: check-idf
    #!/usr/bin/env bash
    set -euo pipefail
    source {{idf_path}}/export.sh
    idf.py build

# Clean build files
[group: "build"]
clean: check-idf
    #!/usr/bin/env bash
    set -euo pipefail
    source {{idf_path}}/export.sh
    idf.py clean

# Full clean (removes build directory and generated sdkconfig)
[confirm("Remove build directory and generated sdkconfig?")]
[group: "build"]
fullclean: check-idf
    #!/usr/bin/env bash
    set -euo pipefail
    source {{idf_path}}/export.sh
    idf.py fullclean
    rm -f sdkconfig

# Open configuration menu
[group: "build"]
menuconfig: check-idf
    #!/usr/bin/env bash
    set -euo pipefail
    source {{idf_path}}/export.sh
    idf.py menuconfig

# Show binary size analysis
[group: "build"]
size: check-idf
    #!/usr/bin/env bash
    set -euo pipefail
    source {{idf_path}}/export.sh
    idf.py size

# Show per-component size breakdown
[group: "build"]
size-components: check-idf
    #!/usr/bin/env bash
    set -euo pipefail
    source {{idf_path}}/export.sh
    idf.py size-components

##########
# Device
##########

# Flash firmware to ESP32-CAM (GPIO0 must be connected to GND)
[group: "device"]
flash: check-idf
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Make sure GPIO0 is connected to GND for programming mode"
    source {{idf_path}}/export.sh
    idf.py -p {{port}} flash

# Monitor serial output (Ctrl+] to exit)
[group: "device"]
monitor: check-idf
    #!/usr/bin/env bash
    set -euo pipefail
    source {{idf_path}}/export.sh
    idf.py -p {{port}} monitor

# Flash and immediately start monitoring
[group: "device"]
flash-monitor: check-idf
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Make sure GPIO0 is connected to GND for programming mode"
    source {{idf_path}}/export.sh
    idf.py -p {{port}} flash monitor

# Build, flash, and monitor (full development cycle)
[group: "device"]
develop: build flash-monitor

##########
# Info
##########

# Show project information
[group: "info"]
info:
    @echo "{{project_name}} — AI Vision with Telegram Integration"
    @echo "ESP-IDF Path: {{idf_path}}"
    @echo "Serial Port:  {{port}}"
    @echo ""
    @echo "Features:"
    @echo "  Camera capture with OV2640"
    @echo "  LLM-powered image analysis"
    @echo "  Telegram bot interface"
    @echo "  Motor control via vision commands"
    @echo ""
    @echo "Note: Credentials are in main/config.h (placeholder values)."
    @echo "  Edit config.h with your WiFi, Telegram, and LLM API credentials."
    @echo "  Uses custom partition table (partitions.csv)."
    @echo "  data/prompts.txt is embedded into the binary at build time."
    @echo ""
    @echo "Programming ESP32-CAM:"
    @echo "  1. Connect GPIO0 to GND"
    @echo "  2. Power on or reset the board"
    @echo "  3. Run: just flash or just flash-monitor"
    @echo "  4. Disconnect GPIO0 from GND after flashing"
    @echo "  5. Reset the board to run the new firmware"
