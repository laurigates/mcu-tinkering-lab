/**
 * @file credentials.h.example
 * @brief Template for WiFi and API credentials
 *
 * Copy this file to credentials.h and fill in your actual credentials
 */

#ifndef CREDENTIALS_H
#define CREDENTIALS_H

// WiFi Configuration
#define WIFI_SSID "your_wifi_network_name"
#define WIFI_PASSWORD "your_wifi_password"

// Gemini API Configuration (planner backend — required)
// Get your key from: https://aistudio.google.com/apikey
#define GEMINI_API_KEY "your_gemini_api_key_from_google"

#endif // CREDENTIALS_H
