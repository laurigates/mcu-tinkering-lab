# ESP-IDF Robocar Unified (XIAO ESP32-S3 Sense)
# Run `just --list` to see available recipes

set positional-arguments

import '../../../tools/esp32.just'

project_dir := "packages/esp32-projects/robocar-unified"
port := env("PORT", _detected_s3)
target := "esp32s3"

default:
    @just --list

##########
# Build (containerized)
##########

# Build the firmware
[group: "build"]
build:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Building robocar-unified..."
    {{container_cmd}} compose -f {{compose_file}} run --rm \
        -w /workspace/{{project_dir}} \
        esp-idf \
        bash -c "idf.py set-target {{target}} && idf.py build"

# Clean build files
[group: "build"]
clean:
    #!/usr/bin/env bash
    set -euo pipefail
    {{container_cmd}} compose -f {{compose_file}} run --rm \
        -w /workspace/{{project_dir}} \
        esp-idf \
        idf.py fullclean
    echo "Clean complete"

# Open configuration menu
[group: "build"]
menuconfig:
    {{container_cmd}} compose -f {{compose_file}} run --rm \
        -w /workspace/{{project_dir}} \
        esp-idf \
        idf.py menuconfig

# Interactive shell in ESP-IDF container
[group: "build"]
shell:
    {{container_cmd}} compose -f {{compose_file}} run --rm \
        -w /workspace/{{project_dir}} \
        esp-idf \
        /bin/bash

##########
# Flash & Monitor (native — XIAO ESP32-S3 uses native USB-Serial-JTAG)
##########

# Flash firmware to XIAO ESP32-S3 Sense
[group: "device"]
flash: require-port
    #!/usr/bin/env bash
    set -euo pipefail
    esptool --chip esp32s3 -p {{port}} -b 460800 \
        --before default-reset --after hard-reset \
        write-flash --flash-mode dio --flash-size detect \
        0x0 build/bootloader/bootloader.bin \
        0x8000 build/partition_table/partition-table.bin \
        0x12000 build/robocar-unified.bin
    echo "Flashed OK"

# Monitor serial output (Ctrl-C to stop)
[group: "device"]
monitor: _serial-monitor

# Flash and immediately start monitoring
[group: "device"]
flash-monitor: flash monitor

##########
# Info
##########

# Show project information
[group: "info"]
info:
    @echo "Robocar Unified (Single-Board)"
    @echo "  Target:    ESP32-S3"
    @echo "  Port:      {{port}}"
    @echo "  Container: {{container_cmd}}"
    @echo "  Hardware:  XIAO ESP32-S3 Sense + TCA9548A + PCA9685"
