# Gamepad Synth — BLE controller-driven synthesizer
# Run `just --list` to see available recipes

set positional-arguments

import '../../../tools/esp32.just'

project_dir := "packages/esp32-projects/gamepad-synth"
port := env("PORT", _detected_s3)
target := "esp32s3"

# Bluepad32 local external directory (symlinked from xbox-switch-bridge or cloned by CI)
bp32_ext := justfile_directory() / "external/bluepad32"

default:
    @just --list

##########
# Setup
##########

# Ensure bluepad32 deps exist (symlink from xbox-switch-bridge or clone)
[group: "setup"]
fetch-deps:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ -d "{{bp32_ext}}/src" ]; then
        echo "Bluepad32 deps already present"
        exit 0
    fi
    # Try symlinking from xbox-switch-bridge (avoids duplicate clones)
    XBOX_BP32="$(dirname "{{bp32_ext}}")/../xbox-switch-bridge/external/bluepad32"
    if [ -d "$XBOX_BP32/src" ]; then
        mkdir -p "$(dirname "{{bp32_ext}}")"
        ln -sfn "$(cd "$XBOX_BP32" && pwd)" "{{bp32_ext}}"
        echo "Symlinked bluepad32 from xbox-switch-bridge"
    else
        echo "xbox-switch-bridge deps not found — fetching for xbox-switch-bridge first..."
        just xbox::fetch-deps
        mkdir -p "$(dirname "{{bp32_ext}}")"
        ln -sfn "$(cd "$XBOX_BP32" && pwd)" "{{bp32_ext}}"
        echo "Symlinked bluepad32 from xbox-switch-bridge"
    fi

##########
# Build (containerized)
##########

# Build firmware in Docker container
[group: "build"]
build: fetch-deps
    {{container_cmd}} compose -f {{compose_file}} run --rm \
        -w /workspace/{{project_dir}} \
        esp-idf \
        bash -c "idf.py build 2>&1 | grep -vE '^\[[0-9]+/[0-9]+\] (Building|Generating|Creating|No |Compiling|Linking)'"

# Set target and clean build (only needed when switching chip targets)
[group: "build"]
set-target: fetch-deps
    {{container_cmd}} compose -f {{compose_file}} run --rm \
        -w /workspace/{{project_dir}} \
        esp-idf \
        idf.py set-target {{target}}

# Clean build artifacts
[group: "build"]
clean:
    {{container_cmd}} compose -f {{compose_file}} run --rm \
        -w /workspace/{{project_dir}} \
        esp-idf \
        idf.py fullclean

# Open menuconfig
[group: "build"]
menuconfig:
    {{container_cmd}} compose -f {{compose_file}} run --rm \
        -w /workspace/{{project_dir}} \
        esp-idf \
        idf.py menuconfig

# Interactive shell in ESP-IDF container
[group: "build"]
shell:
    {{container_cmd}} compose -f {{compose_file}} run --rm \
        -w /workspace/{{project_dir}} \
        esp-idf \
        /bin/bash

##########
# Flash & Monitor (native)
##########

# Flash firmware to device
[group: "device"]
flash: require-port
    esptool --chip esp32s3 -p {{port}} -b 460800 \
        --before default-reset --after hard-reset \
        write_flash --flash-mode dio --flash-size 4MB --flash-freq 80m \
        0x0 build/bootloader/bootloader.bin \
        0x8000 build/partition_table/partition-table.bin \
        0x10000 build/gamepad-synth.bin

# Monitor serial output
[group: "device"]
monitor: _serial-monitor

# Build, flash, and monitor
[group: "device"]
develop: build flash monitor

# Show project info
[group: "info"]
info:
    @echo "Project: gamepad-synth"
    @echo "  Target: ESP32-S3"
    @echo "  Port:   {{if port == "" { "(not detected)" } else { port } }}"
    @echo "  Bluepad32: {{bp32_ext}}"
