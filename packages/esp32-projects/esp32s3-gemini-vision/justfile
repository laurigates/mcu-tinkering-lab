# XIAO ESP32-S3 Sense + Gemini Robotics-ER vision demo
# Run `just --list` to see available recipes

set positional-arguments

import '../../../tools/esp32-idf.just'
import '../../../tools/esp32-credentials.just'

project_dir := "packages/esp32-projects/esp32s3-gemini-vision"
port := env("PORT", _detected_s3)
target := "esp32s3"

default:
    @just --list

##########
# Setup
##########

# Copy credentials template on first build
[group: "setup"]
credentials: (_credentials "edit WIFI_SSID, WIFI_PASSWORD, GEMINI_API_KEY")

##########
# Build (containerized)
##########

# Build firmware (containerized)
[group: "build"]
build: credentials _idf-build

# Clean build artifacts (containerized)
[group: "build"]
clean: _idf-clean

# Open sdkconfig menu (containerized)
[group: "build"]
menuconfig: _idf-menuconfig

# Interactive shell in ESP-IDF container
[group: "build"]
shell: _idf-shell

##########
# Flash & Monitor (native — XIAO uses USB-Serial-JTAG)
##########

# Flash firmware
[group: "device"]
flash: require-port
    #!/usr/bin/env bash
    set -euo pipefail
    esptool --chip esp32s3 -p {{port}} -b 460800 \
        --before default-reset --after hard-reset \
        write-flash --flash-mode dio --flash-size detect \
        0x0 build/bootloader/bootloader.bin \
        0x8000 build/partition_table/partition-table.bin \
        0x10000 build/esp32s3-gemini-vision.bin
    echo "Flashed OK"

# Monitor serial output (Ctrl-C to stop)
[group: "device"]
monitor: _serial-monitor

# Build, flash, then monitor
[group: "device"]
flash-monitor: flash monitor

# Full dev cycle
[group: "device"]
develop: build flash monitor

##########
# Info
##########

# Show project information
[group: "info"]
info:
    @echo "esp32s3-gemini-vision"
    @echo "  Target:   ESP32-S3"
    @echo "  Hardware: XIAO ESP32-S3 Sense (OV2640, 8MB PSRAM)"
    @echo "  AI:       Gemini Robotics-ER 1.5 (cloud, on-demand)"
    @echo "  Port:     {{port}}"
    @echo "  URL:      http://xiao-vision.local/"
