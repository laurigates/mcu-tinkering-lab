# IT Troubleshooter — ESP32-S3-Zero USB composite device
# Run `just --list` for available recipes

set positional-arguments

import '../../../tools/esp32.just'

project_dir := justfile_directory()
tools_dir := justfile_directory() / "../../.." / "tools"
port := env("PORT", _detected_s3)
baud := env("BAUD", "460800")

##########
# Default
##########

default:
    @just --list

##########
# Setup
##########

# Create credentials.h from example template (required before first build)
[group: "setup"]
setup:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ -f main/credentials.h ]; then
        echo "main/credentials.h already exists — no changes made"
    else
        cp main/credentials.h.example main/credentials.h
        echo "Created main/credentials.h — edit with your WiFi SSID, password, and API key"
    fi

##########
# Build
##########

# Build firmware in Docker container
[group: "build"]
build:
    docker compose -f {{compose_file}} run --rm \
        -w /workspace/packages/esp32-projects/it-troubleshooter \
        esp-idf \
        bash -c "idf.py set-target esp32s3 && idf.py build"

# Clean build artifacts
[group: "build"]
[confirm("Remove build/, sdkconfig, and managed_components?")]
clean:
    rm -rf build sdkconfig sdkconfig.old managed_components

##########
# Device (flash & monitor — native, USB passthrough on macOS is unreliable)
##########

# Auto-detect ESP32-S3 port or show error
[group: "device"]
detect-port:
    "{{tools_dir}}/detect-esp32s3-port.sh"

# Flash firmware to device
[group: "device"]
flash: require-port
    cd {{project_dir}}/build && esptool --chip esp32s3 -p {{port}} -b {{baud}} \
        --before default-reset --after hard-reset \
        write-flash @flash_args

# Build and flash
[group: "device"]
deploy: build flash

##########
# Monitor & Reset
##########

# Reset board via USB-Serial-JTAG CDC control signals
[group: "device"]
reset: require-port
    "{{tools_dir}}/esp32s3-reset.sh" "{{port}}"

# Serial monitor with reset (Ctrl-C to stop)
[group: "device"]
monitor: require-port
    "{{tools_dir}}/esp32s3-monitor.sh" "{{port}}"

##########
# Config
##########

# Run menuconfig in Docker
[group: "config"]
menuconfig:
    docker compose -f {{compose_file}} run --rm \
        -w /workspace/packages/esp32-projects/it-troubleshooter \
        esp-idf \
        idf.py menuconfig

##########
# Info
##########

# Show project information
[group: "info"]
info:
    @echo "Project: it-troubleshooter"
    @echo "  Target: ESP32-S3"
    @echo "  Port:   {{if port == "" { "(not detected — board not connected?)" } else { port } }}"
    @echo "  Baud:   {{baud}}"
