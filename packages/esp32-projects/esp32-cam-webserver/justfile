# ESP32-CAM Live Video Streaming Web Server
# Run `just` or `just --list` to see available recipes

set positional-arguments

import '../../../tools/esp32-idf.just'

project_dir := "packages/esp32-projects/esp32-cam-webserver"
port := env("PORT", _detected_serial)
target := "esp32"

default:
    @just --list

##########
# Setup
##########

# Create credentials file from template
[group: "setup"]
credentials:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ ! -f main/credentials.h ]; then
        cp main/credentials.h.example main/credentials.h
        echo "Created main/credentials.h — edit it with your WiFi credentials"
    else
        echo "Credentials file exists"
    fi

# Build the firmware (requires credentials)
[group: "build"]
build: credentials _idf-build

# Clean build artifacts (containerized)
[group: "build"]
clean: _idf-clean

# Open configuration menu (containerized)
[group: "build"]
menuconfig: _idf-menuconfig

# Interactive shell in ESP-IDF container
[group: "build"]
shell: _idf-shell

##########
# Code Quality
##########

# Run cppcheck on source files
[group: "quality"]
lint:
    cppcheck --enable=warning,style,performance --suppress=missingIncludeSystem main/

# Format source files with clang-format
[group: "quality"]
format:
    clang-format -i main/*.c main/*.h 2>/dev/null || true

# Check formatting without modifying files
[group: "quality"]
format-check:
    clang-format --dry-run --Werror main/*.c main/*.h 2>/dev/null || true

##########
# Flash & Monitor (native — USB passthrough on macOS is unreliable)
##########

# Flash firmware to ESP32-CAM (GPIO0 must be connected to GND)
[group: "device"]
flash: require-port
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Make sure GPIO0 is connected to GND for programming mode"
    esptool --chip esp32 -p {{port}} -b 460800 \
        --before default-reset --after hard-reset \
        write-flash --flash-mode dio --flash-size detect \
        0x1000 build/bootloader/bootloader.bin \
        0x8000 build/partition_table/partition-table.bin \
        0x10000 build/esp32-cam-webserver.bin
    echo "Flashed OK — disconnect GPIO0 from GND and reset"

# Monitor serial output (Ctrl-C to stop)
[group: "device"]
monitor: _serial-monitor

# Flash and immediately start monitoring
[group: "device"]
flash-monitor: flash monitor

# Build, flash, and monitor (full development cycle)
[group: "device"]
develop: build flash-monitor

##########
# Info
##########

# Show project information and programming instructions
[group: "info"]
info:
    @echo "esp32-cam-webserver — Live Video Streaming Web Server"
    @echo "  Target:    ESP32"
    @echo "  Port:      {{port}}"
    @echo "  Container: {{container_cmd}}"
    @echo ""
    @echo "Programming ESP32-CAM:"
    @echo "  1. Connect GPIO0 to GND"
    @echo "  2. Power on or reset the board"
    @echo "  3. Run: just flash or just flash-monitor"
    @echo "  4. Disconnect GPIO0 from GND after flashing"
    @echo "  5. Reset the board to run the new firmware"
