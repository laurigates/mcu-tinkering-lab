# ESP32-CAM Live Video Streaming Web Server
# Run `just` or `just --list` to see available recipes

set positional-arguments

idf_path := env("IDF_PATH", home_directory() + "/repos/esp-idf")
port := env("PORT", "/dev/cu.usbserial-0001")
project_name := "esp32-cam-webserver"

default:
    @just --list

[private]
check-idf:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ ! -d "{{idf_path}}" ]; then
        echo "Error: ESP-IDF not found at {{idf_path}}"
        echo "Install ESP-IDF or set IDF_PATH variable"
        exit 1
    fi

##########
# Setup
##########

# Create credentials file from template
[group: "setup"]
credentials:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ ! -f main/credentials.h ]; then
        cp main/credentials.h.example main/credentials.h
        echo "Created main/credentials.h — edit it with your WiFi credentials"
    else
        echo "Credentials file exists"
    fi

##########
# Build
##########

# Build the firmware
[group: "build"]
build: check-idf credentials
    #!/usr/bin/env bash
    set -euo pipefail
    source {{idf_path}}/export.sh
    idf.py build

# Clean build files
[group: "build"]
clean: check-idf
    #!/usr/bin/env bash
    set -euo pipefail
    source {{idf_path}}/export.sh
    idf.py clean

# Full clean (removes build directory and generated sdkconfig)
[group: "build"]
[confirm("This will remove the build directory and sdkconfig. Continue?")]
fullclean: check-idf
    #!/usr/bin/env bash
    set -euo pipefail
    source {{idf_path}}/export.sh
    idf.py fullclean
    rm -f sdkconfig

# Open configuration menu
[group: "build"]
menuconfig: check-idf
    #!/usr/bin/env bash
    set -euo pipefail
    source {{idf_path}}/export.sh
    idf.py menuconfig

##########
# Code Quality
##########

# Run cppcheck on source files
[group: "quality"]
lint:
    cppcheck --enable=warning,style,performance --suppress=missingIncludeSystem main/

# Format source files with clang-format
[group: "quality"]
format:
    clang-format -i main/*.c main/*.h 2>/dev/null || true

# Check formatting without modifying files
[group: "quality"]
format-check:
    clang-format --dry-run --Werror main/*.c main/*.h 2>/dev/null || true

##########
# Flash & Monitor
##########

# Flash firmware to ESP32-CAM (GPIO0 must be connected to GND)
[group: "device"]
flash: check-idf
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Make sure GPIO0 is connected to GND for programming mode"
    source {{idf_path}}/export.sh
    idf.py -p {{port}} flash

# Monitor serial output (Ctrl+] to exit)
[group: "device"]
monitor: check-idf
    #!/usr/bin/env bash
    set -euo pipefail
    source {{idf_path}}/export.sh
    idf.py -p {{port}} monitor

# Flash and immediately start monitoring
[group: "device"]
flash-monitor: check-idf
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Make sure GPIO0 is connected to GND for programming mode"
    source {{idf_path}}/export.sh
    idf.py -p {{port}} flash monitor

# Build, flash, and monitor (full development cycle)
[group: "device"]
develop: build flash-monitor

##########
# Info
##########

# Show project information and programming instructions
[group: "info"]
info:
    @echo "{{project_name}} — Live Video Streaming Web Server"
    @echo "ESP-IDF Path: {{idf_path}}"
    @echo "Serial Port:  {{port}}"
    @echo ""
    @echo "Programming ESP32-CAM:"
    @echo "  1. Connect GPIO0 to GND"
    @echo "  2. Power on or reset the board"
    @echo "  3. Run: just flash or just flash-monitor"
    @echo "  4. Disconnect GPIO0 from GND after flashing"
    @echo "  5. Reset the board to run the new firmware"
