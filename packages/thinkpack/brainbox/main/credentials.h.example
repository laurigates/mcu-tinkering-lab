/**
 * Copy this file to credentials.h and fill in your actual credentials.
 * credentials.h is gitignored — never commit it.
 */
#ifndef CREDENTIALS_H
#define CREDENTIALS_H

// WiFi credentials
#define WIFI_SSID "YourNetworkName"
#define WIFI_PASSWORD "YourNetworkPassword"

// AI backend API keys (only the one you've selected via menuconfig is required)
#define CLAUDE_API_KEY "sk-ant-api03-..."
#define GEMINI_API_KEY "AIza..."

// Ollama base URL — leave as the default to let mDNS discover _ollama._tcp.local,
// or hardcode like "http://192.168.1.42:11434" to skip discovery.
#define OLLAMA_BASE_URL ""

#endif
