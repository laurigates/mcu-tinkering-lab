# ThinkPack Brainbox — LLM-driven mesh coordinator firmware
# Run `just` or `just --list` to see available recipes

set positional-arguments

import '../../../tools/esp32-idf.just'

project_dir := "packages/thinkpack/brainbox"
bin_name := "thinkpack-brainbox"
port := env("PORT", _detected_s3)
target := "esp32s3"

default:
    @just --list

##########
# Setup
##########

# Verify or create main/credentials.h from the example template
[private]
credentials:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ ! -f main/credentials.h ]; then
        echo "ERROR: main/credentials.h is missing" >&2
        echo "  cp main/credentials.h.example main/credentials.h" >&2
        echo "  Then edit it with your WiFi SSID, password, and API key." >&2
        exit 1
    fi
    echo "main/credentials.h present"

##########
# Build
##########

# Build firmware in Docker container (requires credentials; validated build)
[group: "build"]
build: credentials (_idf-build-checked bin_name)

# Clean build artifacts (containerized)
[group: "build"]
clean: _idf-clean

# Open configuration menu — select AI backend here
[group: "build"]
menuconfig: _idf-menuconfig

# Interactive shell in ESP-IDF container
[group: "build"]
shell: _idf-shell

##########
# Flash & Monitor
##########

# Flash firmware to ESP32-S3 Brainbox (standard S3 layout)
[group: "device"]
flash: (_s3-flash bin_name)

# Reset board via USB-Serial-JTAG CDC control signals
[group: "device"]
reset: _s3-reset

# Serial monitor with reset (Ctrl-C to stop)
[group: "device"]
monitor: _s3-monitor

# Flash and monitor
[group: "device"]
flash-monitor: flash monitor

##########
# OTA (PR F) — ESP-NOW relay
##########

# Trigger an OTA push from Brainbox to all followers over ESP-NOW.
#
# The Brainbox firmware listens for the string "OTA-PUSH-ALL\n" on its
# USB-Serial-JTAG CDC console at any time after boot and calls
# ota_handler_check_and_push_all(0xFF) when it sees it. This recipe
# sends that trigger over the current serial port.
#
# The handler is deliberately minimal today: it emits a log-only
# placeholder, because the HTTP-stream-to-RAM fetch is pending
# hardware verification. Use this recipe as the canonical entry point
# for end-to-end testing once the fetch path lands.
[group: "ota"]
ota-push-all: require-port
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Sending OTA-PUSH-ALL trigger on {{port}}..."
    printf 'OTA-PUSH-ALL\n' > "{{port}}"
    echo "Trigger sent — watch 'just monitor' for broadcaster log lines."

##########
# Info
##########

# Show project information
[group: "info"]
info:
    @echo "ThinkPack Brainbox"
    @echo "  Target:    ESP32-S3 (WROOM N8R8 recommended)"
    @echo "  Port:      {{port}}"
    @echo "  Container: {{container_cmd}}"
    @echo "  Pins:      GPIO4=WS2812, GPIO5=Piezo, GPIO9=Button"
    @echo ""
    @echo "AI backend: select via 'just menuconfig' → ThinkPack Brainbox Configuration"
    @echo "            (Claude / Ollama / Gemini)"
    @echo ""
    @echo "Quick start:"
    @echo "  1. cp main/credentials.h.example main/credentials.h && \$EDITOR main/credentials.h"
    @echo "  2. just build"
    @echo "  3. just flash-monitor"
